# Johny Morning Brief — Environment Variables
# Copy this file to .env for local testing
# For GitHub Actions: add these as Repository Secrets

# Anthropic API Key (required)
ANTHROPIC_API_KEY=sk-ant-...

# LINE OA Messaging API
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here
LINE_USER_ID=your_line_user_id_here

# Google Calendar (handled via MCP — no token needed if MCP is configured)
CALENDAR_EMAIL=siripong.ro@gmail.com

# Notion (handled via MCP — no token needed if MCP is configured)
# NOTION_TOKEN=secret_...  # only needed if running outside MCP context

# Git config for commit in CI
GIT_USER_NAME=Johny
GIT_USER_EMAIL=johny-bot@users.noreply.github.com
